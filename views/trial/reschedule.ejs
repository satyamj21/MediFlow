<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>MediFlow – Reschedule</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/mediflow.css">
  <style>
    .form-card { max-width: 560px; }

    .current-banner {
      background: var(--blue-pale);
      border: 1px solid #bfdbfe;
      border-radius: 8px;
      padding: 13px 15px;
      margin-bottom: 18px;
      display: flex;
      gap: 28px;
      flex-wrap: wrap;
    }
    .cb-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.09em; color: var(--gray-400); margin-bottom: 3px; }
    .cb-val   { font-size: 13px; font-weight: 700; color: var(--gray-900); }
    .cb-sub   { font-size: 11.5px; color: var(--gray-500); }

    .time-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin-top:5px; }
    .time-btn {
      border: 1.5px solid var(--gray-200); border-radius: 7px; padding: 9px 6px;
      text-align: center; font-size: 12.5px; font-weight: 600; cursor: pointer;
      transition: all 0.14s; background: white; color: var(--gray-700);
      font-family: 'DM Sans', sans-serif;
    }
    .time-btn:hover    { border-color: var(--accent); color: var(--accent-dark); background: var(--yellow-pale); }
    .time-btn.selected { border-color: var(--accent); background: var(--yellow-pale); color: var(--accent-dark); }

    .submit-row { display:flex; gap:9px; margin-top:20px; }
    .submit-row .btn { flex:1; justify-content:center; padding:11px; font-size:13.5px; }
  </style>
</head>
<body>


<aside class="sidebar">
  <div class="sidebar-brand">
    <div class="logo-wrap"><%- icon('hospital') %></div>
    <span class="brand-name">MediFlow</span>
  </div>
  <div class="sidebar-section-label">Navigation</div>
  <nav>
    <a href="/user"><span class="nav-icon"><%- icon('dashboard') %></span> Dashboard</a>
    <a href="/book"><span class="nav-icon"><%- icon('calendar') %></span> Book Appointment</a>
    <a href="/appointments" class="active"><span class="nav-icon"><%- icon('appointments') %></span> My Appointments</a>
    <a class="nav-disabled"><span class="nav-icon"><%- icon('queue') %></span> Live Queue</a>
  </nav>
  <div class="sidebar-spacer"></div>
  <div class="sidebar-divider"></div>
  <% if (typeof curruser !== 'undefined' && curruser) { %>
  <div class="sidebar-user">
    <div class="avatar"><%= curruser.username[0].toUpperCase() %></div>
    <div>
      <div class="user-name"><%= curruser.username %></div>
      <div class="user-role"><%= curruser.role %></div>
    </div>
  </div>
  <% } %>
  <form action="/logout" method="GET">
    <button class="logout-btn"><%- icon('logout') %> Logout</button>
  </form>
</aside>

<main class="main">
  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <div class="flash flash-success"><%- icon('success') %> <%= success %></div>
  <% } %>
  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="flash flash-error"><%- icon('warning') %> <%= error %></div>
  <% } %>

  <div class="page-header">
    <h1>Reschedule Appointment</h1>
    <p>Update the doctor, date or time for your appointment.</p>
  </div>

  <div class="card form-card">
    <div class="card-header-row">
      <div>
        <h2>Update Appointment</h2>
        <p>Current details are pre-filled below</p>
      </div>
    </div>
    <div class="card-body">

      <div class="current-banner">
        <div>
          <div class="cb-label">Current Doctor</div>
          <div class="cb-val"><%= appointment.doctor.name %></div>
          <div class="cb-sub"><%= appointment.doctor.specialization %></div>
        </div>
        <div>
          <div class="cb-label">Current Date &amp; Time</div>
          <div class="cb-val"><%= new Date(appointment.date).toDateString() %></div>
          <div class="cb-sub"><%= appointment.timeSlot %></div>
        </div>
      </div>

      <form action="/reschedule/<%= appointment._id %>" method="POST">

        <div class="form-group">
          <label class="form-label">Select Doctor</label>
          <select class="form-control" name="doctor">
            <% doctors.forEach(doc => { %>
              <option value="<%= doc._id %>"
                <%= doc._id.toString() === appointment.doctor._id.toString() ? 'selected' : '' %>>
                <%= doc.name %> &ndash; <%= doc.specialization %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label" for="date">Select Date</label>
          <input class="form-control" type="date" name="date" id="date"
            value="<%= appointment.date ? appointment.date.toISOString().split('T')[0] : '' %>" required>
        </div>

        <div class="form-group">
          <label class="form-label">Select Time Slot</label>
          <input type="hidden" name="timeSlot" id="timeSlotInput" value="<%= appointment.timeSlot %>">
          <div class="time-grid">
            <% ['9:00 AM','10:00 AM','11:00 AM','12:00 PM','2:00 PM','3:00 PM'].forEach(t => {
                const val = t.split(' ')[0];
            %>
            <button type="button" class="time-btn <%= appointment.timeSlot === val ? 'selected' : '' %>"
                    data-val="<%= val %>"><%= t %></button>
            <% }) %>
          </div>
        </div>

        <div class="submit-row">
          <a href="/appointments" class="btn btn-ghost"><%- icon('back') %> Back</a>
          <button type="submit" class="btn btn-warning"><%- icon('edit') %> Update Appointment</button>
        </div>

      </form>
    </div>
  </div>
</main>

<script>
  document.querySelectorAll('.time-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.time-btn').forEach(b => b.classList.remove('selected'));
      this.classList.add('selected');
      document.getElementById('timeSlotInput').value = this.dataset.val;
    });
  });
  document.getElementById('date').min = new Date().toISOString().split('T')[0];
</script>
</body>
</html>
